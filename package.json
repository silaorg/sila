{
  "name": "sila",
  "description": "Root package for Sila's monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "land": "node packages/silaland/src/cli.js",
    "dev": "concurrently --kill-others-on-fail -n land,web -c yellow,cyan \"npm run dev:land\" \"npm run dev:web\"",
    "dev:land": "node packages/silaland/src/cli.js run test-land --watch",
    "dev:web": "npm run dev -w web",
    "test": "npm run --workspaces --if-present test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
